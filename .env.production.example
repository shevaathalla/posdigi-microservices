# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this file to .env and update with production values

# PostgreSQL Database Configuration
DB_HOST=your-production-db-host
DB_PORT=5432
DB_NAME=posdigi_microservices
DB_USER=posdigi_app_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# MongoDB Configuration (Activity Logs)
MONGODB_HOST=your-production-mongodb-host
MONGODB_PORT=27017
MONGODB_DATABASE=posdigi_activity_logs
MONGODB_USERNAME=posdigi_app_user
MONGODB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
MONGODB_AUTH_DB=admin
MONGODB_CONNECTION_TIMEOUT=10
MONGODB_POOL_LIMIT=100

# Service Ports (Internal - only expose Gateway via firewall)
AUTH_PORT=8001
USER_PORT=8002
ATTENDANCE_PORT=8003
GATEWAY_PORT=8000

# Service URLs (for inter-service communication - use Docker service names)
USER_SERVICE_URL=http://user-service:8002
AUTH_SERVICE_URL=http://auth-service:8001
ATTENDANCE_SERVICE_URL=http://attendance-service:8003

# JWT Configuration (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=CHANGE_THIS_MINIMUM_32_CHAR_SECRET
JWT_EXPIRY=24

# Internal Service Communication (CHANGE THIS IN PRODUCTION!)
INTERNAL_SERVICE_KEY=CHANGE_THIS_MINIMUM_24_CHAR_SECRET

# Logging (Use INFO or WARNING in production)
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=production

# Gateway Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m